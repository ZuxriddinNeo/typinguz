{
  "name": "@typeuz/util",
  "exports": {
    "./*": {
      "types": "./src/*.ts",
      "import": "./dist/*.mjs",
      "require": "./dist/*.js"
    }
  },
  "scripts": {
    "dev": "tsup-node --watch",
    "build": "madge --circular --extensions ts ./src && tsup-node",
    "test": "vitest run",
    "madge": " madge --circular --extensions ts ./src",
    "ts-check": "tsc --noEmit",
    "lint": "oxlint . --type-aware --type-check",
    "lint-fast": "oxlint ."
  },
  "devDependencies": {
    "@types/node": "24.9.1",
    "madge": "8.0.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "tsup": "8.4.0",
    "typescript": "6.0.2",
    "vitest": "4.1.0",
    "zod": "3.23.8",
    "@typeuz/tsup-config": "workspace:*",
    "@typeuz/typescript-config": "workspace:*"
  }
}
