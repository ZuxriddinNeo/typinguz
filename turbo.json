{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "tasks": {
    "parallel": {
      "dependsOn": ["^parallel"]
    },
    "lint": {
      "dependsOn": ["^parallel", "^build"]
    },
    "lint-fast": {
      "dependsOn": ["^parallel", "^build"]
    },
    "ts-check": {
      "dependsOn": ["^parallel"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "integration-test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "storybook": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "start": {
      "dependsOn": ["build"]
    },
    "@typeuz/frontend#check-assets": {
      "dependsOn": ["^parallel", "@typeuz/schemas#build"]
    },
    "//#lint-styles": {
      "dependsOn": ["^parallel"]
    },
    "@typeuz/frontend#lint-json": {
      "dependsOn": ["^parallel"]
    },
    "@typeuz/frontend#build": {
      "dependsOn": ["^build"],
      "env": ["BACKEND_URL", "RECAPTCHA_SITE_KEY", "SENTRY", "VITE_GOOGLE_CLIENT_ID"],
      "outputs": ["dist/**"]
    },
    "@typeuz/frontend#dev": {
      "dependsOn": ["^build"],
      "env": ["BACKEND_URL", "RECAPTCHA_SITE_KEY", "SERVER_OPEN", "VITE_GOOGLE_CLIENT_ID"],
      "persistent": true
    },
    "@typeuz/backend#dev": {
      "dependsOn": ["^build"],
      "env": ["DB_URI", "REDIS_URI", "PORT", "JWT_SECRET", "FRONTEND_URL", "ALLOWED_ORIGINS"],
      "persistent": true
    }
  }
}
